{
	"name": "@repo/database",
	"version": "0.0.0",
	"main": "./index.ts",
	"types": "./**/.tsx",
	"scripts": {
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"generate": "dotenv -c -e ../../.env -- prisma generate --no-hints && node -e \"const f='prisma/zod/index.ts',s=require('fs').readFileSync(f,'utf8');if(!s.includes('import { Prisma }'))require('fs').writeFileSync(f,'import { Prisma } from \\\"../generated/client\\\";\\n'+s)\"",
		"push": "dotenv -c -e ../../.env -- prisma db push",
		"migrate": "dotenv -c -e ../../.env -- prisma migrate dev",
		"studio": "dotenv -c -e ../../.env -- prisma studio",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@paralleldrive/cuid2": "^3.3.0",
		"@prisma/adapter-pg": "catalog:",
		"@prisma/client": "catalog:",
		"drizzle-orm": "catalog:",
		"drizzle-zod": "catalog:",
		"pg": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@repo/tsconfig": "workspace:*",
		"@types/node": "catalog:",
		"dotenv": "catalog:",
		"dotenv-cli": "catalog:",
		"drizzle-kit": "catalog:",
		"prisma": "catalog:",
		"prisma-zod-generator": "catalog:"
	}
}
